{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure",
            "type": "shell",
            "command": "cmake -S . -B build -G Ninja -DCMAKE_BUILD_TYPE=Debug",
            "group": "build",
            "options": { "cwd": "${workspaceFolder}" },
            "presentation": { "reveal": "always", "panel": "dedicated" }
        },
        {
            "label": "Build",
            "type": "shell",
            "command": "cmake --build build --parallel",
            "group": { "kind": "build", "isDefault": true },
            "options": { "cwd": "${workspaceFolder}" },
            "presentation": { "reveal": "always", "panel": "dedicated" },
            "dependsOn": []
        },
        {
            "label": "Configure + Build",
            "type": "shell",
            "command": "cmake -S . -B build -G Ninja -DCMAKE_BUILD_TYPE=Debug && cmake --build build --parallel",
            "group": "build",
            "options": { "cwd": "${workspaceFolder}" },
            "presentation": { "reveal": "always", "panel": "dedicated" }
        },
        {
            "label": "Run Standalone",
            "type": "shell",
            "command": "open build/W2Sampler_artefacts/Debug/Standalone/W2\\ Sampler.app",
            "group": "test",
            "options": { "cwd": "${workspaceFolder}" },
            "dependsOn": ["Build"]
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "rm -rf build",
            "group": "build",
            "options": { "cwd": "${workspaceFolder}" }
        }
    ]
}
