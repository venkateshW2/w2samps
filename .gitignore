# Build output — regenerated by cmake --build
build/

# macOS
.DS_Store
**/.DS_Store

# VSCodium / VS Code
.vscode/*.log

# CMake user files
CMakeUserPresets.json

# Compiled objects (shouldn't be in repo)
*.o
*.a
*.dylib

# Plugin installs (the copies in system plugin folders)
~/Library/Audio/Plug-Ins/

# Xcode
*.xcodeproj/
*.xcworkspace/
DerivedData/
